{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": false,
    "noEmit": true,
    "strict": true,
    "target": "es2022",
    "lib": ["es2022", "dom", "dom.iterable"],
    "skipLibCheck": true
  },
  "include": ["static/**/*.js", "static/**/*.d.ts"],
  "exclude": ["static/vendor/**", "node_modules"]
}
